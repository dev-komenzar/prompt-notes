{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui-2/main/node_modules/@tauri-apps/cli/schema.json",
  "productName": "PromptNotes",
  "version": "0.1.0",
  "identifier": "com.devkomenzar.promptnotes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "title": "PromptNotes",
    "windows": [
      {
        "title": "PromptNotes",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "dialog": {}
  }
}
